<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Undangan Pernikahan</title>

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Poppins', sans-serif;
      background:#fdf8f5;
      color:#333;
      overflow-x:hidden;
    }

    .hero{
      height:100vh;
      background:
      linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)),
      url('https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=1200&auto=format&fit=crop');
      background-size:cover;
      background-position:center;
      display:flex;
      justify-content:center;
      align-items:center;
      text-align:center;
      color:white;
      padding:20px;
    }

    .hero-content{
      animation:fadeIn 2s ease;
    }

    .hero h1{
      font-family:'Great Vibes', cursive;
      font-size:70px;
      margin-bottom:10px;
    }

    .hero p{
      font-size:18px;
      letter-spacing:2px;
    }

    .section{
      padding:80px 20px;
      text-align:center;
    }

    .section h2{
      font-family:'Great Vibes', cursive;
      font-size:50px;
      color:#c58f7c;
      margin-bottom:20px;
    }

    .card{
      max-width:700px;
      margin:auto;
      background:white;
      padding:40px;
      border-radius:20px;
      box-shadow:0 10px 30px rgba(0,0,0,0.08);
    }

    .couple{
      font-size:30px;
      font-weight:600;
      margin-bottom:15px;
      color:#444;
    }

    .date{
      font-size:20px;
      margin:20px 0;
      color:#777;
    }

    .location{
      margin-top:15px;
      line-height:1.8;
    }

    .btn{
      display:inline-block;
      margin-top:25px;
      padding:14px 28px;
      background:#c58f7c;
      color:white;
      text-decoration:none;
      border-radius:50px;
      transition:0.3s;
    }

    .btn:hover{
      background:#a76f5c;
      transform:scale(1.05);
    }

    .gallery{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:15px;
      margin-top:40px;
    }

    .gallery img{
      width:100%;
      height:300px;
      object-fit:cover;
      border-radius:20px;
    }

    footer{
      background:#c58f7c;
      color:white;
      text-align:center;
      padding:25px;
      margin-top:50px;
    }

    @keyframes fadeIn{
      from{
        opacity:0;
        transform:translateY(20px);
      }
      to{
        opacity:1;
        transform:translateY(0);
      }
    }

    @media(max-width:768px){
      .hero h1{
        font-size:50px;
      }

      .section h2{
        font-size:40px;
      }

      .card{
        padding:25px;
      }
    }
  </style>
</head>
<body>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <p>THE WEDDING OF</p>
      <h1>Rina & Fajar</h1>
      <p>12 Desember 2026</p>
    </div>
  </section>

  <!-- OPENING -->
  <section class="section">
    <h2>Assalamu'alaikum</h2>

    <div class="card">
      <p>
        Dengan memohon rahmat dan ridho Allah SWT,
        kami mengundang Bapak/Ibu/Saudara/i
        untuk hadir dalam acara pernikahan kami.
      </p>

      <div class="couple">
        Rina Putri & Fajar Ramadhan
      </div>

      <div class="date">
        Minggu, 12 Desember 2026<br>
        Pukul 10.00 WIB
      </div>

      <div class="location">
        Gedung Serbaguna Bahagia<br>
        Jl. Mawar Indah No. 10<br>
        Jakarta Selatan
      </div>

      <a href="https://maps.google.com" class="btn" target="_blank">
        Lihat Lokasi
      </a>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section">
    <h2>Gallery</h2>

    <div class="gallery">
      <img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf?q=80&w=1200&auto=format&fit=crop" alt="">
      
      <img src="https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=1200&auto=format&fit=crop" alt="">
      
      <img src="https://images.unsplash.com/photo-1515934751635-c81c6bc9a2d8?q=80&w=1200&auto=format&fit=crop" alt="">
    </div>
  </section>

  <!-- CLOSING -->
  <section class="section">
    <div class="card">
      <h2>Terima Kasih</h2>

      <p>
        Merupakan suatu kehormatan dan kebahagiaan
        bagi kami apabila Bapak/Ibu/Saudara/i
        berkenan hadir dan memberikan doa restu.
      </p>

      <br>

      <p>Kami yang berbahagia</p>

      <div class="couple">
        Rina & Fajar
      </div>
    </div>
  </section>

  <footer>
    © 2026 Wedding Invitation
  </footer>

</body>
</html>
